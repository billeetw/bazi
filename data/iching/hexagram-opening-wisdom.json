{
  "description": "64卦卦辭第一句智慧：original, modernMeaning, cultivationCore",
  "hexagrams": {
    "1": {"original":"元亨利貞","modernMeaning":"創始之勢俱備，但須守正才能長久。","cultivationCore":"強而不亢，自強不息。"},
    "2": {"original":"元亨，利牝馬之貞","modernMeaning":"順勢承載可得亨通，柔順而有方向。","cultivationCore":"厚德載物，以柔守正。"},
    "3": {"original":"元亨利貞，勿用有攸往","modernMeaning":"初創艱難，不宜躁進。","cultivationCore":"起步重穩，不求速成。"},
    "4": {"original":"亨，匪我求童蒙","modernMeaning":"學習需主動，教化在啟發。","cultivationCore":"謙受教，立規矩。"},
    "5": {"original":"有孚，光亨，貞吉","modernMeaning":"有信念則等待有光。","cultivationCore":"守信待時。"},
    "6": {"original":"有孚窒惕，中吉","modernMeaning":"有理亦當戒慎。","cultivationCore":"理直氣和。"},
    "7": {"original":"貞，丈人吉","modernMeaning":"組織需德行領導。","cultivationCore":"紀律與責任。"},
    "8": {"original":"吉，原筮元永貞","modernMeaning":"選擇依附需慎重。","cultivationCore":"擇善而從。"},
    "9": {"original":"亨","modernMeaning":"小積累亦可通達。","cultivationCore":"積少成多。"},
    "10": {"original":"履虎尾，不咥人，亨","modernMeaning":"臨險守禮則通。","cultivationCore":"謹慎行事。"},
    "11": {"original":"小往大來，吉亨","modernMeaning":"陰陽交通，局勢通泰。","cultivationCore":"順勢而治。"},
    "12": {"original":"否之匪人，不利君子貞","modernMeaning":"氣機不通，守正自保。","cultivationCore":"閉塞時守德。"},
    "13": {"original":"同人于野，亨","modernMeaning":"志同者方可成事。","cultivationCore":"以道聚人。"},
    "14": {"original":"元亨","modernMeaning":"資源充足，但需節度。","cultivationCore":"富而好禮。"},
    "15": {"original":"亨，君子有終","modernMeaning":"謙德可保始終。","cultivationCore":"謙而有度。"},
    "16": {"original":"利建侯行師","modernMeaning":"動員需有方向。","cultivationCore":"喜中有序。"},
    "17": {"original":"元亨利貞","modernMeaning":"順勢而動方吉。","cultivationCore":"隨時不失本。"},
    "18": {"original":"元亨，利涉大川","modernMeaning":"整治積弊需決心。","cultivationCore":"治根不治標。"},
    "19": {"original":"元亨利貞","modernMeaning":"接近他人需守德。","cultivationCore":"以德臨人。"},
    "20": {"original":"盥而不薦，有孚顒若","modernMeaning":"觀察重在誠敬。","cultivationCore":"先觀後行。"},
    "21": {"original":"亨，利用獄","modernMeaning":"清除阻礙方可通。","cultivationCore":"果斷清障。"},
    "22": {"original":"亨，小利有攸往","modernMeaning":"修飾有益，但不宜大動。","cultivationCore":"文以載道。"},
    "23": {"original":"不利有攸往","modernMeaning":"衰退期不宜進。","cultivationCore":"保核心。"},
    "24": {"original":"亨，出入無疾","modernMeaning":"回歸正道可無咎。","cultivationCore":"回頭不晚。"},
    "25": {"original":"元亨利貞","modernMeaning":"守正自然通。","cultivationCore":"真誠無妄。"},
    "26": {"original":"利貞，不家食吉","modernMeaning":"蓄養大德可成事。","cultivationCore":"蓄勢待發。"},
    "27": {"original":"貞吉","modernMeaning":"養正則吉。","cultivationCore":"慎養其心。"},
    "28": {"original":"棟橈，利有攸往","modernMeaning":"承重過度需調整。","cultivationCore":"卸載再行。"},
    "29": {"original":"習坎，有孚維心亨","modernMeaning":"險中守信則通。","cultivationCore":"守心穿險。"},
    "30": {"original":"利貞，亨","modernMeaning":"依附光明可通。","cultivationCore":"明而不炫。"},
    "31": {"original":"亨，利貞，取女吉","modernMeaning":"感應相通可亨，但需守正。","cultivationCore":"情動守禮，感而有度。"},
    "32": {"original":"亨，無咎，利貞，利有攸往","modernMeaning":"持續而正，方能長久前行。","cultivationCore":"恆久不變其志。"},
    "33": {"original":"亨，小利貞","modernMeaning":"退避有道，守正為吉。","cultivationCore":"退而保全。"},
    "34": {"original":"利貞","modernMeaning":"力量充足，但須守正。","cultivationCore":"強而有節。"},
    "35": {"original":"康侯用錫馬蕃庶，晝日三接","modernMeaning":"向上發展，宜得賞識與支持。","cultivationCore":"光明進取。"},
    "36": {"original":"利艱貞","modernMeaning":"光受傷時，守正於艱難。","cultivationCore":"藏光養晦。"},
    "37": {"original":"利女貞","modernMeaning":"家內有序，守位則吉。","cultivationCore":"內政清明。"},
    "38": {"original":"小事吉","modernMeaning":"分歧之時，宜小不宜大。","cultivationCore":"求同存異。"},
    "39": {"original":"利西南，不利東北；利見大人，貞吉","modernMeaning":"困難中需轉向求助。","cultivationCore":"改道求援。"},
    "40": {"original":"利西南；無所往，其來復吉；有攸往，夙吉","modernMeaning":"困解之後，宜回歸整頓。","cultivationCore":"解後修整。"},
    "41": {"original":"有孚，元吉，無咎，可貞","modernMeaning":"減損得當，可得大吉。","cultivationCore":"以減成全。"},
    "42": {"original":"利有攸往，利涉大川","modernMeaning":"增益得勢，宜積極前行。","cultivationCore":"利他而益己。"},
    "43": {"original":"揚于王庭，孚號，有厲","modernMeaning":"決斷需公開與警惕。","cultivationCore":"決而不躁。"},
    "44": {"original":"女壯，勿用取女","modernMeaning":"突遇強勢，不宜輕結合。","cultivationCore":"慎對誘惑。"},
    "45": {"original":"亨，王假有廟","modernMeaning":"聚集得勢，宜立中心。","cultivationCore":"聚而有序。"},
    "46": {"original":"元亨，用見大人，勿恤","modernMeaning":"循序上升，勿憂。","cultivationCore":"穩步漸進。"},
    "47": {"original":"亨，貞，大人吉，無咎","modernMeaning":"困中守正，可轉為通。","cultivationCore":"困而不失志。"},
    "48": {"original":"改邑不改井","modernMeaning":"環境變，根基不變。","cultivationCore":"守本修基。"},
    "49": {"original":"己日乃孚，元亨利貞，悔亡","modernMeaning":"變革需時機成熟。","cultivationCore":"時至而變。"},
    "50": {"original":"元吉，亨","modernMeaning":"制度成器，吉而通達。","cultivationCore":"立器成事。"},
    "51": {"original":"亨，震來虩虩，笑言啞啞","modernMeaning":"驚動之後，可安然。","cultivationCore":"動中守定。"},
    "52": {"original":"艮其背，不獲其身","modernMeaning":"止於所當止。","cultivationCore":"知止而安。"},
    "53": {"original":"女歸吉，利貞","modernMeaning":"漸進而正，終得其所。","cultivationCore":"循序不躁。"},
    "54": {"original":"征凶，無攸利","modernMeaning":"位不正，行則凶。","cultivationCore":"審位而行。"},
    "55": {"original":"亨，王假之","modernMeaning":"盛大之時，宜承天命。","cultivationCore":"盛而守中。"},
    "56": {"original":"小亨，旅貞吉","modernMeaning":"在外守正，小成可得。","cultivationCore":"守禮自持。"},
    "57": {"original":"小亨，利有攸往，利見大人","modernMeaning":"以柔入事，循序得通。","cultivationCore":"柔順滲透。"},
    "58": {"original":"亨，利貞","modernMeaning":"喜悅交流，守正為本。","cultivationCore":"悅而不失節。"},
    "59": {"original":"亨，王假有廟，利涉大川","modernMeaning":"離散之中，重建中心。","cultivationCore":"散而再聚。"},
    "60": {"original":"亨，苦節不可貞","modernMeaning":"節制有度，過則不宜。","cultivationCore":"限度之道。"},
    "61": {"original":"豚魚吉，利涉大川","modernMeaning":"誠信可通大事。","cultivationCore":"內外一致。"},
    "62": {"original":"亨，利貞","modernMeaning":"小步前行，守正可通。","cultivationCore":"低飛過關。"},
    "63": {"original":"亨，小利貞，初吉終亂","modernMeaning":"完成之後，仍需警惕。","cultivationCore":"成後守成。"},
    "64": {"original":"亨，小狐汔濟，濡其尾","modernMeaning":"將成未成，慎於最後一步。","cultivationCore":"未完待續。"}
